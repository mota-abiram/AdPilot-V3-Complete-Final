# AdPilot V3 Environment Variables
# Copy this file to .env and fill in the actual values
# NEVER commit .env with real credentials to the repository

# ─── Meta Ads API ─────────────────────────────────────────────────
# Get from Meta App Dashboard → Settings → Tokens → System User Token
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_your_account_id_here

# META CLIENT — REVASA AURA (if applicable)
META_REVASA_AURA_ACCESS_TOKEN=your_revasa_aura_token_here
META_REVASA_AURA_AD_ACCOUNT_ID=your_revasa_aura_account_id_here

# ─── Google Ads API ───────────────────────────────────────────────
# Get from Google Cloud Console → OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_MCC_ID=your_mcc_id_here
GOOGLE_CUSTOMER_ID=your_customer_id_here

# ─── Anthropic Claude API ────────────────────────────────────────
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── OpenAI API Key (for creative generation) ──────────────────────
# Get from platform.openai.com → API Keys
OPENAPI_API_KEY=sk-proj-...

# ─── Groq API (optional) ────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Gemini Model (optional) ────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash

# ─── Database ───────────────────────────────────────────────────
# For local dev: postgres://user:password@localhost:5432/ad_pilot
# For Render: Use internal Postgres URL (postgres://dpg-xxxxx-a) or external with ?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/ad_pilot

# ─── App Access Management ──────────────────────────────────────
# Generate a strong random value with: openssl rand -hex 32
SESSION_SECRET=your_strong_random_session_secret_here

# Bootstrap admin account (initial setup only)
AUTH_BOOTSTRAP_EMAIL=admin@adpilot.local
AUTH_BOOTSTRAP_PASSWORD=change_to_strong_password_here
AUTH_BOOTSTRAP_NAME=Administrator

# ─── Node Environment ───────────────────────────────────────────
NODE_ENV=development
